{
   "name": "llm-bench",
   "version": "0.1.0",
   "type": "module",
   "description": "Local LLM benchmark suite: triage, reasoning, tool-calling, long-context KV, summarization",
   "engines": {
      "node": ">=22"
   },
   "scripts": {
      "dry-run":     "node runners/run-suite.mjs --dry-run",
      "bench":       "node runners/run-suite.mjs",
      "smoke":       "node runners/smoke.mjs",
      "chart":       "node runners/render-chart.mjs",
      "results":     "node runners/results-to-md.mjs",
      "judge-prep":  "node runners/judge-prep.mjs",
      "judge-merge": "node runners/judge-merge.mjs",
      "deploy":      "bash scripts/deploy.sh",
      "lint":        "biome lint shared runners benchmarks",
      "format":      "biome format --write shared runners benchmarks",
      "check":       "biome check --write shared runners benchmarks"
   },
   "devDependencies": {
      "@biomejs/biome": "^2.4.16",
      "promptfoo": "^0.121.13"
   },
   "dependencies": {
      "js-yaml": "^4.2.0",
      "jsonrepair": "^3.14.0",
      "openai": "^6.41.0"
   }
}
