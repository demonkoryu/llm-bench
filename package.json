{
   "name": "llm-bench",
   "version": "0.1.0",
   "type": "module",
   "description": "Local LLM benchmark suite: triage, reasoning, tool-calling, long-context KV, summarization",
   "engines": {
      "node": ">=22"
   },
   "scripts": {
      "bench": "node runners/bench-run.mjs",
      "dashboard": "node app/server.mjs",
      "dashboard:export": "node analysis/export-dashboard.mjs",
      "pg:sync": "node analysis/pg-sync.mjs",
      "backfill": "node analysis/backfill.mjs",
      "caps-seed": "node analysis/caps-cache.mjs seed",
      "smoke": "node runners/smoke.mjs",
      "coding-smoke": "node runners/coding-smoke.mjs",
      "deploy": "bash scripts/deploy.sh",
      "lint": "biome lint shared runners benchmarks analysis app benches",
      "format": "biome format --write shared runners benchmarks analysis app benches",
      "check": "biome check --write shared runners benchmarks analysis app benches"
   },
   "devDependencies": {
      "@biomejs/biome": "^2.4.16",
      "promptfoo": "^0.121.13"
   },
   "dependencies": {
      "@duckdb/node-api": "^1.5.4-r.1",
      "js-yaml": "^4.2.0",
      "jsonrepair": "^3.14.0",
      "openai": "^6.41.0",
      "sharp": "^0.34.5"
   }
}
