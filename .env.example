# Central Postgres store (central-db @ 192.168.1.120) — the single source of truth for
# measurement rows. Copy to `.env` and fill in LLMBENCH_DB_PASSWORD (the llmbench role
# password). `.env` is gitignored; analysis/pg-store.mjs auto-loads it when these vars are
# not already present in the environment (so CI, which sets the secret directly, ignores it).
LLMBENCH_PG_HOST=192.168.1.120
LLMBENCH_PG_PORT=5432
LLMBENCH_PG_DB=llmbench
LLMBENCH_PG_USER=llmbench
LLMBENCH_DB_PASSWORD=
